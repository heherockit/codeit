# ── General ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/codit.log
DRY_RUN=false

# ── Azure DevOps ─────────────────────────────────────────────────────────────
AZURE_DEVOPS_ORGANIZATION=YOUR_ADO_ORGANIZATION
AZURE_DEVOPS_PROJECT=YOUR_ADO_PROJECT
AZURE_DEVOPS_PAT=your_personal_access_token_here
AZURE_DEVOPS_API_VERSION=7.1
AZURE_DEVOPS_WORK_ITEM_TYPE=Task
AZURE_DEVOPS_WORK_ITEM_STATE=Active
AZURE_DEVOPS_ASSIGNED_TO=
AZURE_DEVOPS_IN_PROGRESS_STATE=In Progress
AZURE_DEVOPS_COMPLETED_STATE=Done

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_EXECUTABLE=git
GIT_WORKSPACE_PATH=/path/to/your/repos
GIT_BASE_BRANCH=dev-sprint
GIT_BRANCH_PREFIX=feature

# ── Augment CLI ───────────────────────────────────────────────────────────────
AUGMENT_CLI_PATH=auggie.cmd
AUGMENT_TIMEOUT_SECONDS=1800
AUGMENT_MODEL=claude-opus-4.6

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT_KEY=ITM
JIRA_IN_PROGRESS_STATE=In Progress
JIRA_COMPLETED_STATE=Done

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_BASE_URL=https://gitlab.com
GITLAB_PRIVATE_TOKEN=your_private_token_here
GITLAB_PROJECT_ID=123
GITLAB_IN_PROGRESS_STATE=In Progress
GITLAB_COMPLETED_STATE=Closed

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_personal_access_token_here
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name
GITHUB_IN_PROGRESS_STATE=open
GITHUB_COMPLETED_STATE=closed

